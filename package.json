{
  "name": "gamereason-storefront",
  "version": "1.0.0",
  "private": true,
  "description": "GameReason storefront for buying PC games with React, Node.js, and layered testing.",
  "workspaces": [
    "apps/*",
    "tests/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace client",
    "dev:client": "npm run dev --workspace client",
    "dev:server": "npm run dev --workspace server --if-present",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose stop postgres",
    "prod:up": "docker compose up -d --build",
    "prod:down": "docker compose down",
    "prod:logs": "docker compose logs -f",
    "test:api:smoke": "npx --yes newman@6 run docs/postman/GameReason-Auth-smoke.postman_collection.json",
    "test:api:regression": "npx --yes newman@6 run docs/postman/GameReason-Auth-final.postman_collection.json",
    "test:api:postman": "npm run test:api:regression",
    "test": "npm run test --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "format": "npm run format --workspaces --if-present"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
